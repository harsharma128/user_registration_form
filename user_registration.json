{
  "title": "User Registration",
  "steps": [
    {
      "title": "Personal Details",
      "fields": [
        {
          "type": "text",
          "name": "fullName",
          "label": "Full Name",
          "placeholder": "Enter your name",
          "floatingLabel": true,
          "required": true,
          "regex": "^[A-Za-z]+(?: [A-Za-z]+)*$",
          "regexError": "Enter a valid full name"
        },
        {
          "type": "phone",
          "name": "phone",
          "label": "Phone Number",
          "placeholder": "Enter 10-digit phone",
          "floatingLabel": true,
          "required": true,
          "regex": "^\\d{10}$",
          "regexError": "Phone number must be 10 digits"
        },
        {
          "type": "date",
          "name": "dob",
          "label": "Date of Birth",
          "placeholder": "Select DOB",
          "required": true
        },
        {
          "type": "email",
          "name": "email",
          "label": "Email",
          "placeholder": "Enter your email",
          "floatingLabel": true,
          "required": true,
          "regex": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$",
          "regexError": "Enter a valid email address"
        }
      ]
    },
    {
      "title": "Identity Details",
      "fields": [
        {
          "type": "text",
          "name": "panNumber",
          "label": "PAN Number",
          "placeholder": "Enter PAN (e.g. ABCDE1234F)",
          "floatingLabel": true,
          "required": true,
          "regex": "^[A-Z]{5}[0-9]{4}[A-Z]$",
          "regexError": "PAN must be in format ABCDE1234F"
        },
        {
          "type": "text",
          "name": "aadharNumber",
          "label": "Aadhaar Number",
          "placeholder": "Enter 12-digit Aadhaar number",
          "floatingLabel": true,
          "required": true,
          "regex": "^\\d{12}$",
          "regexError": "Aadhaar number must be 12 digits"
        }
      ]
    },
    {
      "title": "Document Upload",
      "fields": [
        {
          "type": "file",
          "name": "document",
          "label": "Upload Document",
          "placeholder": "Choose file",
          "required": true
        }
      ]
    }
  ]
}